# ==============================================================================
# SECRETS — Copy this file to secrets.yaml and fill in your keys.
# secrets.yaml is in .gitignore and must NEVER be committed.
# ==============================================================================

alpaca:
  api_key: "YOUR_ALPACA_API_KEY"
  secret_key: "YOUR_ALPACA_SECRET_KEY"
  base_url: "https://paper-api.alpaca.markets"  # paper endpoint

polygon:
  api_key: "YOUR_POLYGON_KEY"

ibkr:
  host: "127.0.0.1"
  port: 7497            # 7497 = paper, 7496 = live TWS
  client_id: 1

tradier:
  api_key: "YOUR_TRADIER_KEY"
  account_id: "YOUR_ACCOUNT_ID"
  sandbox: true
